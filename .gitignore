# Raw data exports — large, immutable, reproducible from the source harness.
data/raw/

# Bulk derived JSONLs — kept on disk for local work, regenerable via
# scripts/ingest_exports.py. Excluded from git to keep the repo small;
# the docs (SUMMARY.md, DATASET_NOTES.md), index (manifest.jsonl), and
# the demos directory stay tracked.
data/store/*.jsonl
data/dataset/*.jsonl
data/publish/*.jsonl

# Internal planning and harvest-team comms (not for public repo)
docs/internal/

# HF model-repo staging area — derived from gemma4_finetune/adapters_*/
# and other tracked sources; do not commit duplicates.
gemma4_finetune/publish_hf*/

# Training-run logs and memory samplers — ephemeral artifacts of T0-T5.
gemma4_finetune/*_memlog.txt
gemma4_finetune/*_training.log
gemma4_finetune/setup.log
gemma4_finetune/baseline_n20/run.log
gemma4_finetune/tier*_progress.txt
gemma4_finetune/tier*_inventory.txt
gemma4_finetune/tier*_pipeline.txt
gemma4_finetune/tier2_picks.json
gemma4_finetune/tier2_e2b_baseline.json
gemma4_finetune/tier2_e2b_responses/
gemma4_finetune/teacher_picks_n20.json
gemma4_finetune/postcutover_slice.jsonl
gemma4_finetune/baseline_n20/
# N=20 bench result trees (metric JSONs + per-state response dumps).
# Regenerable from the committed *_runner.py / score_*.py scripts; the
# findings are narrated in docs/reports/. Covers gemma4, gemma4_text, future.
gemma4_finetune/baseline_n20_gemma4*/
# LoRA adapter weights — large (100s of MB per variant). Covers t5, v2, v3,
# proxy, and any future adapter directories. Keep these out of git history.
gemma4_finetune/adapters_*/
gemma4_finetune/dataset_proxy/
gemma4_finetune/lora_config.proxy.yaml
gemma4_finetune/lora_config.minismoke.yaml
gemma4_finetune/baseline_n20_runner.py
gemma4_finetune/posttune_n20_runner.py
gemma4_finetune/tier2_runner.py
