# Raw data exports — large, immutable, reproducible from the source harness.
data/raw/

# Bulk derived JSONLs — kept on disk for local work, regenerable via
# scripts/ingest_exports.py. Excluded from git to keep the repo small;
# the docs (SUMMARY.md, DATASET_NOTES.md), index (manifest.jsonl), and
# the demos directory stay tracked.
data/store/*.jsonl
data/dataset/training.jsonl
data/dataset/decisions.jsonl
data/publish/*.jsonl

# Internal planning and harvest-team comms (not for public repo)
docs/internal/

# HF model-repo staging area — derived from gemma4_finetune/adapters_t5/
# and other tracked sources; do not commit duplicates.
gemma4_finetune/publish_hf/

